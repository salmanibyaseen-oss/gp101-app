// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  password    String
  name        String
  isAdmin     Boolean   @default(false)
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  lastLogin   DateTime?

  // Subscriptions
  hasWebAccess  Boolean @default(true)   // access to GP101 content
  hasBooksAccess Boolean @default(false) // access to PDF books

  devices       Device[]
  notes         Note[]
  bookAccess    UserBook[]
}

model Device {
  id          String   @id @default(uuid())
  userId      String
  fingerprint String
  userAgent   String
  label       String?
  createdAt   DateTime @default(now())
  lastSeen    DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fingerprint])
}

model Note {
  id        String   @id @default(uuid())
  userId    String
  topicSlug String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, topicSlug])
}

model RegistrationRequest {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

// ── Books ─────────────────────────────────────────────────────────────────

model Book {
  id          String   @id @default(uuid())
  title       String
  description String?
  fileUrl     String   // path to PDF in Supabase Storage
  coverUrl    String?  // optional cover image
  isActive    Boolean  @default(true)  // admin can disable
  price       Float?   // price in EGP (optional, for display)
  createdAt   DateTime @default(now())

  userAccess  UserBook[]
}

// Many-to-many: which users have access to which books
model UserBook {
  id        String   @id @default(uuid())
  userId    String
  bookId    String
  grantedAt DateTime @default(now())
  expiresAt DateTime? // optional expiry per book

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
}
